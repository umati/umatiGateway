@page
@model UmatiGateway.Pages.PubSubModel
@{
    ViewData["Title"] = "PubSub";
}
<h1>Umati PubSub</h1>

<p>Configure your Umati PubSub.</p>

<form method="post">
    <div style="float:left; width:20%">
        <fieldset class="settings-fieldset">
            <legend class="settings-legend">PubSub Provider</legend>
            <label for="MqttUser" class="settings-label">User</label>
            <input type="text" class="settings-input" id="MqttUser" name="MqttUser" value="@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.UserName">
            <label for="Password" class="settings-label">Password</label>
            <input type="password" class="settings-input" id="Password" name="MqttPassword" value="@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.Password">
            <label for="ClientId" class="settings-label">ClientId</label>
            <input type="text" class="settings-input" id="ClientId" name="MqttClientId" value="@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.ClientId">
            <label for="Prefix" class="settings-label">Prefix</label>
            <input type="text" class="settings-input" id="Prefix" name="MqttPrefix" value="@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.Prefix">
            <label for="MqttConnection" class="settings-label">ConnectionUrl</label>
            <input id="MqttConnection" class="settings-input" type="text" name="ConnectionUrl" value="@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.ServerEndpoint">
            <label for="PubSubAllowUntrustedCertificates" class="settings-label">Allow Untrusted Certificates</label>
            <div class="settings-on-off-label">
                <span class="off">Off</span>
                <label class="settings-switch">
                    <input id="PubSubAllowUntrustedCertificates" size="60" type="checkbox" name="PubSubAllowUntrustedCertificates" value="true" @(Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.AllowUntrustedCertificates ? "checked" : "")>
                    <span class="settings-slider"></span>
                </label>
                <span class="on">On</span>
            </div>
            <label for="PublishInterval" class="settings-label">Publish Interval</label>
            <input type="text" class="settings-input" id="PublishInterval" name="PublishInterval" value="@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishInterval">
            <label for="MetaDataUpdateTime" class="settings-label">MetaData Update Time</label>
            <input type="text" class="settings-input" id="MetaDataUpdateTime" name="MetaDataUpdateTime" value="@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.MetaDataUpdateTime">         
            <div class="settings-button-container">
                <button asp-page-handler="Connect" class="settings-button">Connect</button>
                <button asp-page-handler="Disconnect" class="settings-button" style="margin-left:10px">Disconnect</button>
            </div>
        </fieldset>
    </div>
    <div style="float:right; width:79%">
        <fieldset class="settings-fieldset">
            <legend class="settings-legend">Published Nodes</legend>
            <table class="nodetable">
                <thead>
                    <colgroup>
                        <col style="width: 3ch;">
                        <col style="width: 10ch;">
                        <col style="width: 10%;">
                        <col style="width: 10%;">
                        <col style="width: 10%;">
                        <col style="width: 10ch;">
                    </colgroup>
                    <tr>
                        <th>#</th>
                        <th>Type</th>
                        <th>NamespaceUrl</th>
                        <th>Identifier</th>
                        <th>BaseType</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes.Count; i++)
                    {
                        if (@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].GetType().Name == "PublishedNode")
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].Type</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].NamespaceUrl</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].NodeId</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].BaseType</td>
                                <td>
                                    <Button asp-page-handler="RemoveNodeMqttConfig" asp-route-index=@i
                                            class="settings-button">
                                        <img src="~/css/delete.png" />
                                    </Button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </fieldset>
        <fieldset class="settings-fieldset">
            <legend class="settings-legend">Published Child Nodes</legend>
            <table class="nodetable">
                <thead>
                    <colgroup>
                        <col style="width: 3ch;">
                        <col style="width: 10ch;">
                        <col style="width: 10%;">
                        <col style="width: 10%;">
                        <col style="width: 10%;">
                        <col style="width: 10ch;">
                    </colgroup>
                    <tr>
                        <th>#</th>
                        <th>Type</th>
                        <th>NamespaceUrl</th>
                        <th>Identifier</th>
                        <th>BaseType</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes.Count; i++)
                    {
                        if (@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].GetType().Name == "PublishedChildNodes")
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].Type</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].NamespaceUrl</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].NodeId</td>
                                <td>@Model.UmatiGatewayApp.ActiveConfiguration.PubSubProviderConfig.PublishedNodes[i].BaseType</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </fieldset>
        <fieldset class="settings-fieldset">
            <legend class="settings-legend">Resolved Nodes</legend>
            <table class="nodetable">
                <thead>
                    <colgroup>
                        <col style="width: 3ch;">
                        <col style="width: 10ch;">
                        <col style="width: 10%;">
                        <col style="width: 10%;">
                        <col style="width: 10%;">
                        <col style="width: 15ch;">
                    </colgroup>
                    <tr>
                        <th>#</th>
                        <th>Type</th>
                        <th>NamespaceUrl</th>
                        <th>Identifier</th>
                        <th>BaseType</th>
                        <th>NodeId</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.UmatiGatewayApp.PubSubProvider.MachineNodes.Count(); i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@Model.UmatiGatewayApp.PubSubProvider.MachineNodes[i].NodeIdType</td>
                            <td>@Model.UmatiGatewayApp.PubSubProvider.MachineNodes[i].NamespaceUrl</td>
                            <td>@Model.UmatiGatewayApp.PubSubProvider.MachineNodes[i].NodeIdString</td>
                            <td>@Model.UmatiGatewayApp.PubSubProvider.MachineNodes[i].BaseType</td>
                            <td>@Model.UmatiGatewayApp.PubSubProvider.MachineNodes[i].ResolvedNodeId</td>
                        </tr>
                    }
                </tbody>
            </table>
        </fieldset>
    </div>
</form>
